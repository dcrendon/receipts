# Common
# PROVIDER options: gitlab, jira, github, all
PROVIDER=gitlab

# Output file used when provider is gitlab, jira, or github.
# For provider=all, the tool writes output/gitlab_issues.json,
# output/jira_issues.json, and output/github_issues.json.
OUT_FILE=output/gitlab_issues.json

# TIME_RANGE options: week, month, year, custom
TIME_RANGE=week

# AI model used for optional narrative rewrite (requires OPENAI_API_KEY)
AI_MODEL=gpt-4o-mini

# Required when TIME_RANGE=custom. Format: MM-DD-YYYY
START_DATE=01-01-2026
END_DATE=01-31-2026

# GitLab (required when provider=gitlab or all)
GITLAB_PAT=your_gitlab_pat
GITLAB_URL=https://gitlab.com
# Optional report attribution username for GitLab issues/comments
GITLAB_USERNAME=your_gitlab_username

# Jira (required when provider=jira or all)
JIRA_PAT=your_jira_pat
JIRA_URL=https://jira.example.com
JIRA_USERNAME=your_jira_username

# GitHub (required when provider=github or all)
GITHUB_PAT=your_github_pat
GITHUB_URL=https://api.github.com
GITHUB_USERNAME=your_github_username

# AI headline rewrite (optional — set key to enable, omit to skip)
OPENAI_API_KEY=your_openai_api_key
