{
  "tasks": {
    "dev": "deno run --watch main.ts",
    "fmt": "deno fmt",
    "test": "deno test --allow-read --allow-env tests/",
    "start": "deno run --allow-net --allow-env --allow-read --allow-write main.ts",
    "unsafe": "deno run --allow-net --allow-env --allow-read --allow-write --unsafely-ignore-certificate-errors main.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/cli": "jsr:@std/cli@^1.0.24",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5",
    "@std/fmt": "jsr:@std/fmt@^1.0.0",
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0",
    "@cliffy/table": "jsr:@cliffy/table@^1.0.0",
    "date-fns": "npm:date-fns@^4.1.0"
  }
}